/* dcomp_win.c — DirectComposition tree for AuraPlayer (Windows only).
 * Owns: D3D11 device, video swapchain, DComp device/target/visuals.
 * Never touches GL — that's angle_win.c's job.
 */
#ifdef _WIN32

#define COBJMACROS
#include "aura_ctx.h"
#include <stdio.h>

#pragma comment(lib, "d3d11.lib")
#pragma comment(lib, "dxgi.lib")
#pragma comment(lib, "dcomp.lib")

#define AURA_LOG(...) do { fprintf(stderr, "[aura-dcomp] " __VA_ARGS__); \
                           fprintf(stderr, "\n"); fflush(stderr); } while (0)

int aura_dcomp_init(AuraCtx *c, HWND top_level_hwnd)
{
    HRESULT hr;
    c->top_hwnd = top_level_hwnd;
    InitializeCriticalSection(&c->wlock);

    hr = D3D11CreateDevice(
        NULL, D3D_DRIVER_TYPE_HARDWARE, NULL,
        D3D11_CREATE_DEVICE_BGRA_SUPPORT,   /* required by ANGLE + DComp */
        NULL, 0, D3D11_SDK_VERSION,
        &c->d3d11_dev, NULL, &c->d3d11_ctx);
    if (FAILED(hr)) { AURA_LOG("D3D11CreateDevice failed: 0x%08lx", hr); return 0; }

    IDXGIDevice *dxgi = NULL;
    hr = ID3D11Device_QueryInterface(c->d3d11_dev, &IID_IDXGIDevice, (void **)&dxgi);
    if (FAILED(hr)) { AURA_LOG("QI IDXGIDevice failed: 0x%08lx", hr); return 0; }

    hr = DCompositionCreateDevice(dxgi, &IID_IDCompositionDevice,
                                  (void **)&c->dcomp_dev);
    IDXGIDevice_Release(dxgi);
    if (FAILED(hr)) { AURA_LOG("DCompositionCreateDevice failed: 0x%08lx", hr); return 0; }

    /* topmost = TRUE: our tree composites in FRONT of the HWND's legacy
     * (AWT-painted) content. We can't use WS_EX_NOREDIRECTIONBITMAP because
     * AWT created the window. */
    hr = IDCompositionDevice_CreateTargetForHwnd(c->dcomp_dev, c->top_hwnd,
                                                 TRUE, &c->dcomp_target);
    if (FAILED(hr)) { AURA_LOG("CreateTargetForHwnd failed: 0x%08lx", hr); return 0; }

    IDCompositionDevice_CreateVisual(c->dcomp_dev, &c->root_visual);
    IDCompositionDevice_CreateVisual(c->dcomp_dev, &c->video_visual);
    IDCompositionDevice_CreateVisual(c->dcomp_dev, &c->ui_visual);
    if (!c->root_visual || !c->video_visual || !c->ui_visual) {
        AURA_LOG("CreateVisual failed"); return 0;
    }

    /* z-order: video at the bottom, UI above it */
    IDCompositionVisual_AddVisual(c->root_visual, c->video_visual, FALSE, NULL);
    IDCompositionVisual_AddVisual(c->root_visual, c->ui_visual, TRUE,
                                  c->video_visual);
    IDCompositionTarget_SetRoot(c->dcomp_target, c->root_visual);

    AURA_LOG("init ok (hwnd=%p)", (void *)c->top_hwnd);
    return 1;
}

static int create_video_swapchain(AuraCtx *c, int w, int h)
{
    HRESULT hr;
    IDXGIDevice  *dxgi = NULL;
    IDXGIAdapter *adapter = NULL;
    IDXGIFactory2 *factory = NULL;

    ID3D11Device_QueryInterface(c->d3d11_dev, &IID_IDXGIDevice, (void **)&dxgi);
    IDXGIDevice_GetAdapter(dxgi, &adapter);
    IDXGIAdapter_GetParent(adapter, &IID_IDXGIFactory2, (void **)&factory);

    DXGI_SWAP_CHAIN_DESC1 d;
    ZeroMemory(&d, sizeof(d));
    d.Width            = w;
    d.Height           = h;
    d.Format           = DXGI_FORMAT_B8G8R8A8_UNORM;
    d.SampleDesc.Count = 1;
    d.BufferUsage      = DXGI_USAGE_RENDER_TARGET_OUTPUT;
    d.BufferCount      = 2;
    d.SwapEffect       = DXGI_SWAP_EFFECT_FLIP_SEQUENTIAL; /* mandatory for composition */
    d.AlphaMode        = DXGI_ALPHA_MODE_IGNORE;           /* video layer is opaque */

    hr = IDXGIFactory2_CreateSwapChainForComposition(
        factory, (IUnknown *)c->d3d11_dev, &d, NULL, &c->video_sc);

    IDXGIFactory2_Release(factory);
    IDXGIAdapter_Release(adapter);
    IDXGIDevice_Release(dxgi);

    if (FAILED(hr)) {
        AURA_LOG("CreateSwapChainForComposition (video) failed: 0x%08lx", hr);
        return 0;
    }
    IDCompositionVisual_SetContent(c->video_visual, (IUnknown *)c->video_sc);
    return 1;
}

int aura_dcomp_set_video_rect(AuraCtx *c, int x, int y, int w, int h)
{
    if (w <= 0 || h <= 0) return 0;
    EnterCriticalSection(&c->wlock);
    c->video_x = x;
    c->video_y = y;

    if (!c->video_sc) {
        if (!create_video_swapchain(c, w, h)) {
            LeaveCriticalSection(&c->wlock);
            return 0;
        }
        c->video_w = w;
        c->video_h = h;
        aura_angle_ensure_surface(c);
    } else if (w != c->video_w || h != c->video_h) {
        /* All buffer references must be dropped BEFORE ResizeBuffers. */
        aura_angle_release_surface(c);
        HRESULT hr = IDXGISwapChain1_ResizeBuffers(c->video_sc, 0, w, h,
                                                   DXGI_FORMAT_UNKNOWN, 0);
        if (FAILED(hr))
            AURA_LOG("ResizeBuffers failed: 0x%08lx", hr);
        c->video_w = w;
        c->video_h = h;
        aura_angle_ensure_surface(c);
    }

    /* offsets are PHYSICAL pixels relative to the HWND client area */
    IDCompositionVisual_SetOffsetX2(c->video_visual, (float)x);
    IDCompositionVisual_SetOffsetY2(c->video_visual, (float)y);

    LeaveCriticalSection(&c->wlock);
    return 1;
}

void aura_dcomp_attach_ui(AuraCtx *c, IDXGISwapChain3 *sc)
{
    if (!sc) return;
    if (c->ui_sc)
        IDXGISwapChain3_Release(c->ui_sc);
    c->ui_sc = sc;
    IDXGISwapChain3_AddRef(sc);
    IDCompositionVisual_SetContent(c->ui_visual, (IUnknown *)sc);
    AURA_LOG("ui swapchain attached (%p)", (void *)sc);
}

void aura_dcomp_commit(AuraCtx *c)
{
    if (c->dcomp_dev)
        IDCompositionDevice_Commit(c->dcomp_dev);
}

/* Step-1 smoke test: fill the video swapchain teal and present it.
 * If the window turns teal after dcompInit + dcompSetVideoRect +
 * dcompDebugFill + dcompCommit, the whole tree works. Remove later. */
void aura_dcomp_debug_fill(AuraCtx *c)
{
    if (!c->video_sc) { AURA_LOG("debug_fill: no video swapchain yet"); return; }
    EnterCriticalSection(&c->wlock);

    ID3D11Texture2D *back = NULL;
    IDXGISwapChain1_GetBuffer(c->video_sc, 0, &IID_ID3D11Texture2D,
                              (void **)&back);
    ID3D11RenderTargetView *rtv = NULL;
    ID3D11Device_CreateRenderTargetView(c->d3d11_dev,
                                        (ID3D11Resource *)back, NULL, &rtv);
    const FLOAT teal[4] = { 0.11f, 0.62f, 0.46f, 1.0f };
    ID3D11DeviceContext_ClearRenderTargetView(c->d3d11_ctx, rtv, teal);
    ID3D11RenderTargetView_Release(rtv);
    ID3D11Texture2D_Release(back);
    IDXGISwapChain1_Present(c->video_sc, 1, 0);

    LeaveCriticalSection(&c->wlock);
    AURA_LOG("debug fill presented");
}

void aura_dcomp_teardown(AuraCtx *c)
{
    EnterCriticalSection(&c->wlock);

    if (c->dcomp_target)
        IDCompositionTarget_SetRoot(c->dcomp_target, NULL);

    if (c->ui_sc)        { IDXGISwapChain3_Release(c->ui_sc);            c->ui_sc = NULL; }
    if (c->ui_visual)    { IDCompositionVisual_Release(c->ui_visual);    c->ui_visual = NULL; }
    if (c->video_visual) { IDCompositionVisual_Release(c->video_visual); c->video_visual = NULL; }
    if (c->root_visual)  { IDCompositionVisual_Release(c->root_visual);  c->root_visual = NULL; }
    if (c->dcomp_target) { IDCompositionTarget_Release(c->dcomp_target); c->dcomp_target = NULL; }
    if (c->dcomp_dev)    { IDCompositionDevice_Release(c->dcomp_dev);    c->dcomp_dev = NULL; }
    if (c->video_sc)     { IDXGISwapChain1_Release(c->video_sc);         c->video_sc = NULL; }
    if (c->d3d11_ctx)    { ID3D11DeviceContext_Release(c->d3d11_ctx);    c->d3d11_ctx = NULL; }
    if (c->d3d11_dev)    { ID3D11Device_Release(c->d3d11_dev);           c->d3d11_dev = NULL; }

    LeaveCriticalSection(&c->wlock);
    DeleteCriticalSection(&c->wlock);
    AURA_LOG("teardown done");
}

#endif /* _WIN32 */